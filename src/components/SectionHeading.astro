---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
  className?: string;
  titleClass?: string;
  introClass?: string;
}

const { eyebrow, title, intro, align = "left", className, titleClass, introClass } = Astro.props;
const isCentered = align === "center";
---

<div class:list={["max-w-3xl", isCentered && "mx-auto text-center", className]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class:list={["mt-4 text-3xl font-semibold tracking-[-0.04em] text-snow-100 sm:text-4xl lg:text-[2.9rem]", titleClass]}>
    {title}
  </h2>
  {intro && <p class:list={["mt-3 text-sm leading-6 text-snow-200/75 sm:text-base sm:leading-7", introClass]}>{intro}</p>}
</div>
