---
import { siteMeta, withBase } from "../data/site";

const heroImage = withBase("/images/hero-blump.jpeg");
---

<section id="top" class="relative min-h-screen overflow-hidden pt-24">
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: linear-gradient(180deg, rgba(9, 9, 11, 0.14), rgba(9, 9, 11, 0.8)), url('${heroImage}'); background-position: center 48%;`}  ></div>
  <div class="grid-overlay absolute inset-0 opacity-35"></div>
  <div class="ambient-orb left-[-8rem] top-12 h-56 w-56 sm:h-72 sm:w-72"></div>

  <div class="container-shell relative flex min-h-[calc(100vh-7rem)] items-end pb-14 sm:items-center sm:pb-16">
    <div class="max-w-4xl">
      <h1 class="font-display text-6xl font-semibold uppercase tracking-[-0.06em] text-snow-100 sm:text-7xl lg:text-[7rem]">
        BLUMP
      </h1>
      <p class="mt-4 max-w-xl text-lg leading-8 text-snow-200/80 sm:text-xl">
        House, disco edits, and high-energy sets for college nights and club rooms.
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href="#sets" class="button-secondary">
          Listen to Sets
        </a>
        <a href="#booking" class="button-primary">
          Book BLUMP
        </a>
      </div>
    </div>
  </div>

</section>
